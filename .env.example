# Canonical public URL for Open Graph (include https, no trailing slash)
NEXT_PUBLIC_SITE_URL=

# Firebase (create a web app in Firebase console). Required for production admin and cloud bookings.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Business identity (recommended for every public deploy)
NEXT_PUBLIC_BRAND_NAME=
NEXT_PUBLIC_BRAND_TAGLINE=

# WhatsApp desk: digits only, country code first, no plus (example India 919876543210)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# UPI for QR and deep links (leave empty to hide UPI checkout and show pay at shop only)
NEXT_PUBLIC_UPI_ID=

# Google Maps query for directions and embed (full address or plus codes). Leave empty to disable map links in the UI.
NEXT_PUBLIC_MAPS_QUERY=

# Optional longer copy blocks (otherwise safe neutral defaults are used)
NEXT_PUBLIC_BRAND_ADDRESS=
NEXT_PUBLIC_BRAND_HOURS=
NEXT_PUBLIC_BRAND_CONTACT_LEAD=
NEXT_PUBLIC_BRAND_HERO_INTRO=
NEXT_PUBLIC_SOCIAL_PROOF_LINE=
NEXT_PUBLIC_MOBILE_TRUST_LINE=

# Default tenant for /booking when the URL does not include /app/[shopId]. Required for that route to load a real shop.
NEXT_PUBLIC_DEFAULT_SHOP_ID=_default

# Comma separated emails allowed to open /super-admin. Must match firestore.rules superAdminEmailMap()
# and lib/superAdminRulesMirror.ts. Leave empty until you configure admins.
NEXT_PUBLIC_SUPER_ADMIN_EMAILS=

# --- Razorpay Route (optional FastAPI service in /backend) ---
# Server-only secrets: call the backend from a trusted environment, never from the browser.
# See backend/README.md and backend/.env.example for RAZORPAY_KEY_ID, RAZORPAY_KEY_SECRET, etc.
