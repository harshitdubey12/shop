# Razorpay Dashboard: Route-enabled marketplace keys.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx

RAZORPAY_ROUTE_ENABLED=true
PLATFORM_COMMISSION_PAISE=500

# Webhook signing secret from Razorpay Dashboard (required for POST /razorpay/webhook).
RAZORPAY_WEBHOOK_SECRET=xxxxxxxx

# Protects GET/POST /api/v1/admin/* (header X-Admin-Key).
ADMIN_API_KEY=change_me_in_production

# SQLite file (created under cwd when you run uvicorn from ./backend). Use Postgres in production.
DATABASE_URL=sqlite:///./data/app.db

# Optional: mutating /api/v1/razorpay/route/* and /api/v1/bookings/* when set (header X-Route-Internal-Key).
# ROUTE_INTERNAL_API_KEY=

# Optional JSON for POST /v2/accounts when admin approves without sending profile/legal_info in body.
# DEFAULT_ROUTE_ACCOUNT_PROFILE_JSON={"profile": "..."}  # must be full Razorpay profile object
# DEFAULT_ROUTE_ACCOUNT_LEGAL_JSON={"pan":"AAACL1234C"}

# RAZORPAY_BASE_URL=https://api.razorpay.com

# --- Marketplace (India) ---
# FIRST_BOOKING_FEE_WAIVED=true
# PLATFORM_FEE_MIN_PAISE=500
# PLATFORM_FEE_MAX_PAISE=1000
# PEAK_FEE_ENABLED=true
# PEAK_FEE_MULTIPLIER=1.5
# PLATFORM_FEE_MAX_PEAK_PAISE=1500
# Slot hold TTL (seconds). 120 is two minutes for high contention slots.
# HOLD_TTL_SECONDS=120
# AUTO_CONFIRM_SALON_BOOKING=true
# Customer cancel cutoff before slot start (seconds). 7200 is two hours.
# CANCEL_CUTOFF_SECONDS=7200
# LOYALTY_POINTS_PER_BOOKING=10
# WALLET_CREDIT_PER_100_POINTS_PAISE=50
